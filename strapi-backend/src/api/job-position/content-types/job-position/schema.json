{
  "kind": "collectionType",
  "collectionName": "job_positions",
  "info": {
    "singularName": "job-position",
    "pluralName": "job-positions",
    "displayName": "Job Position",
    "description": "Open job positions and career opportunities"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "department": {
      "type": "string",
      "required": true
    },
    "location": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": ["Full-time", "Part-time", "Contract", "Internship"],
      "default": "Full-time",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "responsibilities": {
      "type": "json"
    },
    "requirements": {
      "type": "json"
    },
    "benefits": {
      "type": "json"
    },
    "salary": {
      "type": "string"
    },
    "experience": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
